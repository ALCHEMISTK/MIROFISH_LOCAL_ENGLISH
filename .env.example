# Flask
SECRET_KEY=mirofish-secret-key
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# Frontend
VITE_API_BASE_URL=http://localhost:5001

# LLM configuration
# Default values target a local Ollama instance.
# Replace these three if you want to use a hosted OpenAI-compatible API instead.
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:7b
# When a hosted provider returns a hard quota/usage-limit error, keep polling
# instead of failing immediately. 0 means wait indefinitely.
LLM_QUOTA_WAIT_ENABLED=True
LLM_QUOTA_POLL_SECONDS=10
LLM_QUOTA_MAX_WAIT_SECONDS=0

# Embedding model (optional — auto-detected from provider)
# Local Ollama defaults to nomic-embed-text.
# Cloud providers are auto-detected (OpenAI → text-embedding-3-small, BigModel → embedding-3, etc.)
# Uncomment to override: EMBED_MODEL=nomic-embed-text
# Only needed when using local Ollama embeddings:
OLLAMA_BASE_URL=http://localhost:11434
# Maximum number of nodes in the knowledge graph (LightRAG limit)
LIGHTRAG_MAX_GRAPH_NODES=1000

# Optional boost model
LLM_BOOST_API_KEY=
LLM_BOOST_BASE_URL=
LLM_BOOST_MODEL_NAME=

# Simulation mode: "fast" or "slow"
# fast  = 24h sim, 120min/round, 12 rounds max, fewer agents, semaphore 60
# slow  = 72h sim, 30min/round,  144 rounds max, more agents,  semaphore 30
SIMULATION_MODE=fast
# Individual overrides (optional, only if you want to fine-tune beyond the preset):
# SIM_TOTAL_HOURS=24
# SIM_MINUTES_PER_ROUND=120
# SIM_MAX_ROUNDS=12
# SIM_AGENTS_PER_HOUR_MIN=3
# SIM_AGENTS_PER_HOUR_MAX=10
# SIM_OASIS_SEMAPHORE=60

# Simulation / report tuning
OASIS_DEFAULT_MAX_ROUNDS=10
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5
